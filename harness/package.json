{
  "name": "symbolic-scribe-harness",
  "version": "0.1.1",
  "description": "Repo-aware agent harness for Symbolic Scribe — maintainer/benchmarker/release/security agents with doctor, repo-triage, and release-check commands.",
  "keywords": ["agent-harness", "metaharness", "claude-code", "symbolic-scribe", "mcp", "ai-agent"],
  "homepage": "https://github.com/ruvnet/symbolic-scribe/tree/main/harness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruvnet/symbolic-scribe.git",
    "directory": "harness"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "symbolic-scribe-harness": "./bin/cli.js"
  },
  "files": ["bin/**", "dist/**", "src/**", "tsconfig.json", ".claude/**", "CLAUDE.md", "README.md", "LICENSE"],
  "scripts": {
